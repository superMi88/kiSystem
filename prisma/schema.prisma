// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}


model Conversation {
  id        String        @id @default(uuid())
  title     String        @default("Neuer Chat")
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id             Int          @id @default(autoincrement())
  role           String       // "user" or "ai"
  text           String
  createdAt      DateTime     @default(now())
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
}

model AppLauncher {
  id    Int    @id @default(autoincrement())
  name  String @unique
  path  String
}

model Person {
  id        Int              @id @default(autoincrement())
  name      String?          // Deprecated, für automatische Migration
  notes     String?          // Deprecated, für automatische Migration
  biography String?          // Zuvor 'notes'
  createdAt DateTime         @default(now())
  aliases   PersonAlias[]
  facts     Fact[]
  memories  SemanticMemory[]
  isDeleted Boolean          @default(false)
}

model PersonAlias {
  id        Int      @id @default(autoincrement())
  personId  Int
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  name      String   @unique
  isPrimary Boolean  @default(false)
}

model Fact {
  id        Int      @id @default(autoincrement())
  content   String
  category  String?  // e.g., "game", "hobby", "personal"
  personId  Int
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)
}

model SemanticMemory {
  id        Int                     @id @default(autoincrement())
  content   String
  embedding Unsupported("vector(3072)")
  metadata  Json?                   // { source: "chat", conversationId: "..." }
  personId  Int?
  person    Person?                 @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt DateTime                @default(now())
}

model Timer {
  id        Int      @id @default(autoincrement())
  title     String   @default("Timer")
  expiresAt DateTime
  createdAt DateTime @default(now())
  completed Boolean  @default(false)
  isDeleted Boolean  @default(false)
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
}

model Event {
  id                     Int                @id @default(autoincrement())
  title                  String
  description            String?
  start                  DateTime
  end                    DateTime
  isAllDay               Boolean            @default(false)
  fuzzyTime              String?
  
  recurrenceId           Int?
  recurrence             RecurrencePattern? @relation(fields: [recurrenceId], references: [id], onDelete: Cascade)
  
  originalOccurrenceDate DateTime?
  
  isDeleted              Boolean            @default(false)
  isCancelled            Boolean            @default(false)
  cancellationReason     String?
  
  originalStart          DateTime?
  originalEnd            DateTime?

  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

model RecurrencePattern {
  id              Int       @id @default(autoincrement())
  title           String
  description     String?
  originalStart   DateTime
  originalEnd     DateTime
  isAllDay        Boolean   @default(false)
  fuzzyTime       String?
  recurrenceType  String    // "DAILY" | "WEEKLY" | "MONTHLY"
  recurrenceEnd   DateTime?
  events          Event[]   // Overridden instances linked to this pattern
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isDeleted       Boolean   @default(false)
}



model Task {
  id          Int      @id @default(autoincrement())
  title       String
  notes       String?
  due         DateTime?
  completed   Boolean  @default(false)
  listTitle   String   @default("Standard")
  recurrence  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)
}




